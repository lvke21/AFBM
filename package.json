{
  "name": "afbm-manager",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "postinstall": "prisma generate",
    "test": "vitest",
    "test:run": "vitest run",
    "test:e2e:seed": "tsx scripts/seeds/e2e-seed.ts",
    "test:e2e:dashboard": "npm run test:e2e:seed && node scripts/tools/e2e-preflight.mjs && playwright test e2e/dashboard.spec.ts",
    "test:e2e:navigation": "npm run test:e2e:seed && node scripts/tools/e2e-preflight.mjs && playwright test e2e/navigation.spec.ts",
    "test:e2e:depth-chart": "npm run test:e2e:seed && node scripts/tools/e2e-preflight.mjs && playwright test e2e/depth-chart.spec.ts",
    "test:e2e:action": "npm run test:e2e:seed && node scripts/tools/e2e-preflight.mjs && playwright test e2e/inbox-action.spec.ts",
    "test:e2e:draft": "npm run test:e2e:seed && node scripts/tools/e2e-preflight.mjs && playwright test e2e/draft-mvp.spec.ts",
    "test:e2e:week-loop": "npm run test:e2e:seed && node scripts/tools/e2e-preflight.mjs && playwright test e2e/week-loop.spec.ts",
    "test:e2e": "node scripts/tools/e2e-preflight.mjs && playwright test e2e/smoke.spec.ts",
    "test:e2e:all": "node scripts/tools/e2e-preflight.mjs && playwright test",
    "test:e2e:debug": "node scripts/tools/e2e-preflight.mjs && playwright test e2e/smoke.spec.ts --debug",
    "debug:simulation": "tsx scripts/simulations/simulation-debug-report.ts",
    "qa:production": "tsx scripts/simulations/qa-production-simulation-suite.ts",
    "qa:production:test": "vitest run src/modules/seasons/application/simulation/production-qa.test.ts",
    "db:up": "node scripts/tools/db-up.mjs",
    "db:down": "docker compose down",
    "db:reset": "docker compose down -v && docker compose up -d postgres",
    "firebase:emulators": "firebase emulators:start --only firestore --project demo-afbm",
    "firebase:emulators:export": "firebase emulators:export ./firebase-emulator-data --project demo-afbm",
    "firebase:staging:use": "firebase use staging",
    "firebase:staging:deploy:rules": "firebase deploy --only firestore:rules -P staging",
    "firebase:staging:deploy:indexes": "firebase deploy --only firestore:indexes -P staging",
    "firebase:staging:backfill": "FIRESTORE_PREVIEW_DRY_RUN=true FIRESTORE_PREVIEW_CONFIRM_WRITE=true tsx scripts/firestore-backfill.ts --append",
    "firebase:staging:compare": "FIRESTORE_PREVIEW_DRY_RUN=true tsx scripts/firestore-compare.ts",
    "firebase:seed": "tsx scripts/seeds/firestore-seed.ts",
    "firebase:e2e:browser-fixture": "tsx scripts/seeds/firestore-browser-e2e-fixture.ts",
    "firebase:usage:measure": "tsx scripts/firestore-usage-measure.ts",
    "firebase:reset": "tsx scripts/seeds/firestore-reset.ts",
    "firebase:verify": "tsx scripts/seeds/firestore-verify.ts",
    "firebase:rules:test": "firebase emulators:exec --only firestore --project demo-afbm \"npm run test:firebase:rules\"",
    "test:firebase": "vitest run src/lib/firebase/admin.test.ts src/server/repositories/index.test.ts scripts/seeds/firestore-seed.test.ts",
    "test:firebase:repositories": "vitest run src/server/repositories/firestoreTeamsPlayers.test.ts",
    "test:firebase:season-week-match": "vitest run src/server/repositories/firestoreSeasonWeekMatch.test.ts",
    "test:firebase:week-state": "vitest run src/server/repositories/firestoreWeekMatchState.test.ts",
    "test:firebase:game-output": "vitest run src/server/repositories/firestoreGameOutput.test.ts",
    "test:firebase:stats": "vitest run src/server/repositories/firestoreStatsAggregates.test.ts",
    "test:firebase:readmodels": "vitest run src/server/repositories/firestoreReportsReadModels.test.ts",
    "test:firebase:parity": "firebase emulators:exec --only firestore --project demo-afbm \"vitest run src/server/repositories/firestoreE2eParity.test.ts\"",
    "test:firebase:rules": "vitest run src/lib/firebase/firestore.rules.test.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "prisma db seed"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.10.0",
    "@prisma/client": "6.15.0",
    "firebase": "^12.12.1",
    "firebase-admin": "10.3.0",
    "next": "^15.5.15",
    "next-auth": "^5.0.0-beta.31",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^4.1.0"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.0",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "15.2.9",
    "firebase-tools": "^1.2.0",
    "postcss": "^8.5.0",
    "prisma": "6.15.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.0.0",
    "vitest": "^3.2.0"
  }
}
