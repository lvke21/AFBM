model RosterTransaction {
  id          String                @id @default(cuid())
  saveGameId  String
  playerId    String
  fromTeamId  String?
  toTeamId    String?
  type        RosterTransactionType
  occurredAt  DateTime              @default(now())
  description String?

  saveGame SaveGame @relation(fields: [saveGameId], references: [id], onDelete: Cascade)
  player   Player   @relation(fields: [playerId, saveGameId], references: [id, saveGameId], onDelete: Cascade)
  fromTeam Team?    @relation("RosterTransactionFromTeam", fields: [fromTeamId, saveGameId], references: [id, saveGameId], onDelete: NoAction)
  toTeam   Team?    @relation("RosterTransactionToTeam", fields: [toTeamId, saveGameId], references: [id, saveGameId], onDelete: NoAction)

  @@index([saveGameId, occurredAt])
}

