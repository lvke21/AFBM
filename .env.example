# Local development default. `npm run db:up` starts a matching PostgreSQL container.
AFBM_DEPLOY_ENV="local"
NEXT_PUBLIC_AFBM_DEPLOY_ENV="local"
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/afbm_manager?schema=public"
AFBM_APP_USER_ID="local-gm"

# Online/Admin MVP auth.
# Online players use Firebase Anonymous Auth. Admin access is separate and server-checked.
AFBM_ADMIN_ACCESS_CODE=""
AFBM_ADMIN_SESSION_SECRET=""

# Data backend selection.
# Migration target for local/dev: firestore through the local emulator.
# Use DATA_BACKEND=prisma only as the legacy fallback.
# Do not set DATA_BACKEND=firestore in production until the Firestore rollout is explicitly released.
DATA_BACKEND="firestore"

# Firebase client SDK configuration.
# Production prep only: these values may be configured for the Firebase Web App,
# but they do not switch the active game data backend.
AFBM_ONLINE_BACKEND="local"
NEXT_PUBLIC_AFBM_ONLINE_BACKEND="local"
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=""
NEXT_PUBLIC_FIREBASE_PROJECT_ID="demo-afbm"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=""
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""

# Firebase Admin SDK configuration.
# Server-only. The demo project ID is for the local emulator.
# Keep production DATA_BACKEND=prisma until the production Firestore data path is explicitly released.
FIREBASE_PROJECT_ID="demo-afbm"
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""

# Firestore Preview/Staging dry-run support.
# These variables do not activate Production Firestore.
# Use only with a dedicated non-production Firebase project and never with seed/reset/verify.
FIREBASE_STAGING_PROJECT_ID=""
FIRESTORE_PREVIEW_DRY_RUN="false"
FIRESTORE_PREVIEW_ALLOWLIST_PROJECTS=""
FIRESTORE_PREVIEW_CONFIRM_WRITE="false"
FIRESTORE_PREVIEW_CONFIRM_DELETE="false"
FIREBASE_PRODUCTION_PROJECT_ID=""

# Local emulator support only.
# Do not set these variables in production. Seed/reset/verify scripts use demo-* projects
# and the local emulator guard; production projects must never be targeted by fixture scripts.
FIRESTORE_EMULATOR_HOST="127.0.0.1:8080"
FIREBASE_EMULATOR_HOST="127.0.0.1:8080"
FIREBASE_AUTH_EMULATOR_HOST="127.0.0.1:9099"
NEXT_PUBLIC_FIRESTORE_EMULATOR_HOST="127.0.0.1:8080"
NEXT_PUBLIC_FIREBASE_AUTH_EMULATOR_HOST="127.0.0.1:9099"
